# LDAP
LDAP_DOMAIN=example.com
LDAP_ADMIN_PASSWORD=change_me
LDAP_ORGANISATION=My Company
LDAP_PORT=389
LDAPS_PORT=636
# LDAP server hostname — use ldap-master for the built-in container, or an external host
LDAP_HOST=ldap-master
# Bind DN for Postfix LDAP sender lookup (defaults to cn=admin,dc=<LDAP_DOMAIN parts>)
LDAP_BIND_DN=cn=admin,dc=example,dc=com

# Web
TZ=Asia/Taipei
JWT_SECRET=change_me_to_random_string
SMTP_PORT=25

# Postfix — outbound relay (optional, leave empty for direct MX delivery)
# Format: [smtp.upstream.com]:25
POSTFIX_RELAYHOST=

# iDempiere — Mail Intercept integration
IDEMPIERE_URL=http://idempiere:8080
IDEMPIERE_CLIENT_ID=11
IDEMPIERE_ROLE_ID=102
IDEMPIERE_ORG_ID=11
IDEMPIERE_WAREHOUSE_ID=103
IDEMPIERE_USER=admin
IDEMPIERE_PASS=admin
# API key for nginx reverse proxy in front of iDempiere (leave empty if not used)
IDEMPIERE_API_KEY=
# AD_Table_ID of HR_MailIntercept (required to trigger CompleteIt workflow after record creation)
IDEMPIERE_MAILINTERCEPT_TABLE_ID=0
